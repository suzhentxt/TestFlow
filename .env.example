# Copy this file to .env and replace placeholders with real local secrets.
# Never commit real API keys.

# OpenAI
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Langfuse tracing
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=replace-with-your-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-your-langfuse-secret-key

# Use https://us.cloud.langfuse.com if your Langfuse project is in the US region.
LANGFUSE_HOST=https://cloud.langfuse.com

# Keep false unless you are comfortable sending prompts/source snippets and generated tests to Langfuse.
LANGFUSE_CAPTURE_IO=false
